generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TimeOfDay {
  morning
  afternoon
  evening
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  moodEntries      MoodEntry[]
  reminderSettings ReminderSetting[]
}

model MoodEntry {
  id        String      @id @default(cuid())
  userId    String
  emotion   String
  emoji     String
  note      String?
  timeOfDay TimeOfDay
  date      DateTime
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories Category[] @relation("MoodEntryCategories")

  @@index([userId, date])
}

model Category {
  id          String      @id @default(cuid())
  name        String      @unique
  moodEntries MoodEntry[] @relation("MoodEntryCategories")
}

model ReminderSetting {
  id        String    @id @default(cuid())
  userId    String
  timeOfDay TimeOfDay
  enabled   Boolean   @default(true)
  time      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timeOfDay])
}
