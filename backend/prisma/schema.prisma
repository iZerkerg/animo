generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TimeOfDay {
  morning
  afternoon
  evening
}

enum AchievementCategory {
  consistency
  dailyRhythm
  records
  emotions
  categories
  reflection
  intensity
  special
  secret
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  profileImageUrl     String?
  birthDate           DateTime?
  moodEntries         MoodEntry[]
  reminderSettings    ReminderSetting[]
  passwordResetTokens PasswordResetToken[]
  achievements        UserAchievement[]
}

model Achievement {
  id               String              @id @default(cuid())
  code             String              @unique
  name             String
  description      String
  category         AchievementCategory
  icon             String
  target           Int?
  sortOrder        Int                 @default(0)
  isSecret         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  userAchievements UserAchievement[]

  @@index([category, sortOrder])
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
  @@index([achievementId])
}

model MoodEntry {
  id        String              @id @default(cuid())
  userId    String
  emotion   String
  emoji     String
  note      String?
  timeOfDay TimeOfDay
  date      DateTime
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories Category[]         @relation("MoodEntryCategories")
  emotions  MoodEntryEmotion[]

  @@index([userId, date])
}

model MoodEntryEmotion {
  id          String    @id @default(cuid())
  moodEntryId String
  emotion     String
  emoji        String
  intensity   Int?
  createdAt   DateTime  @default(now())
  moodEntry   MoodEntry @relation(fields: [moodEntryId], references: [id], onDelete: Cascade)

  @@index([moodEntryId])
  @@unique([moodEntryId, emotion])
}

model Category {
  id          String      @id @default(cuid())
  name        String      @unique
  moodEntries MoodEntry[] @relation("MoodEntryCategories")
}

model ReminderSetting {
  id        String    @id @default(cuid())
  userId    String
  timeOfDay TimeOfDay
  enabled   Boolean   @default(true)
  time      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timeOfDay])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
